# ChaseHorse Environment Variables

# Frontend (apps/web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8787

# API Worker (workers/api-gateway/.dev.vars)
JWT_SECRET=change-me-to-a-secure-random-string-32chars
JWT_REFRESH_SECRET=change-me-to-another-secure-string-32c
FRONTEND_URL=http://localhost:3000

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Payments (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Notifications (optional)
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Cloudflare (for deployment)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
