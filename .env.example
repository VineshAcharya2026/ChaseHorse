# ChaseHorse Environment Variables

# Production URLs
# Marketing: https://chasehorse-marketing-8ic.pages.dev
# Web app:   https://chasehorse-app.pages.dev
# API:       https://chasehorse-api.vineshjm.workers.dev

# Frontend (apps/web/.env.development.local for local dev)
NEXT_PUBLIC_API_URL=http://localhost:8787

# Marketing (apps/marketing/.env.development.local for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Marketing reads live CMS content from the API at runtime (falls back to bundled site.json)
# NEXT_PUBLIC_API_URL=http://localhost:8787

# API Worker (workers/api-gateway/.dev.vars)
JWT_SECRET=change-me-to-a-secure-random-string-32chars
JWT_REFRESH_SECRET=change-me-to-another-secure-string-32c
FRONTEND_URL=http://localhost:3000

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Payments (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Notifications (optional)
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Cloudflare (for deployment)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
