{
  "name": "chasehorse",
  "version": "1.0.0",
  "private": true,
  "description": "ChaseHorse — Enterprise Logistics, Courier & Fleet Management Platform",
  "scripts": {
    "build": "turbo run build",
    "build:marketing": "pnpm --filter @chasehorse/marketing build",
    "build:web": "pnpm --filter @chasehorse/web build",
    "deploy:marketing": "pnpm build:marketing && pnpm --filter @chasehorse/marketing deploy:cf",
    "deploy:web": "pnpm build:web && pnpm --filter @chasehorse/web deploy:cf",
    "deploy:production": "pnpm deploy:api && pnpm deploy:marketing && pnpm deploy:web",
    "deploy:api": "pnpm --filter @chasehorse/api-gateway run deploy",
    "dev": "turbo run dev --filter=@chasehorse/api-gateway --filter=@chasehorse/marketing --filter=@chasehorse/web",
    "dev:api": "pnpm --filter @chasehorse/api-gateway dev",
    "db:setup": "pnpm --filter @chasehorse/api-gateway exec wrangler d1 execute chasehorse-db --local --file=../../packages/database/drizzle/0000_init.sql",
    "db:seed": "node scripts/seed-local-api.mjs",
    "db:migrate:remote": "pnpm --filter @chasehorse/api-gateway exec wrangler d1 execute chasehorse-db --remote --file=../../packages/database/drizzle/0000_init.sql",
    "db:seed:remote": "node scripts/seed-local-api.mjs",
    "dev:web": "pnpm --filter @chasehorse/web dev",
    "dev:marketing": "pnpm --filter @chasehorse/marketing dev",
    "extract:odoo": "tsx scripts/extract-odoo-content.ts",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "pnpm --filter @chasehorse/database generate",
    "db:migrate": "pnpm --filter @chasehorse/database migrate"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "cheerio": "^1.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  }
}
